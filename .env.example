# ==================================
# Lifeframe - Environment Variables
# ==================================
# Copy this file to .env and fill in your credentials.
# All variables must be prefixed with VITE_ for Vite to expose them to the client.

# ----- Firebase Configuration -----
# Get these from Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ----- Cloudinary Configuration -----
# Get these from Cloudinary Dashboard
# Cloud Name: found at the top of the Cloudinary dashboard
# Upload Preset: create an unsigned upload preset in Settings > Upload
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
